# Copy to .env.local and fill in your values, then `source .env.local`.
# This is the minimum env for local development with all-local providers
# (no Databricks workspace required).

# ── LLM (pick one) ────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBED_MODEL=text-embedding-3-small

# Alternative: Anthropic for completion + OpenAI for embed (split).
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=          # still required — Anthropic has no embed API

# Alternative: fully local via Ollama.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3

# ── Non-LLM providers (all local) ─────────────────────────────────────────────
CATALOG_PROVIDER=static
STATIC_SCHEMA_FILE=./tests/fixtures/schemas.json

QUERY_PROVIDER=duckdb
DUCKDB_DATA_DIR=./tests/fixtures/data

VECTOR_PROVIDER=chroma
CHROMA_PATH=:memory:

STORE_PROVIDER=sqlite
SQLITE_PATH=:memory:

# ── API server ────────────────────────────────────────────────────────────────
AUTH_DISABLED=true
# TIRI_HOST=0.0.0.0
# TIRI_PORT=8000
# TIRI_LOG_LEVEL=info
